{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {},
    "apps/api": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/web": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["src/routeTree.gen.ts"]
    },
    "packages/shared": {
      "entry": [
        "src/index.ts",
        "src/schemas/index.ts",
        "src/contracts/index.ts",
        "src/types/index.ts",
        "src/constants/index.ts"
      ],
      "project": ["src/**/*.ts"]
    }
  }
}
