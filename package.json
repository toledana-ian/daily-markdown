{
  "name": "daily-markdown-root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter './apps/*' dev & bun run --filter './apps/web' storybook",
    "build": "bun run --filter './apps/*' build",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "bun run --filter './apps/*' test",
    "typecheck": "bun run --filter './apps/*' typecheck",
    "deploy": "cd apps/api && bunx wrangler versions upload",
    "knip": "knip"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "knip": "^5.87.0",
    "lefthook": "^2.1.4",
    "lint-staged": "^15.0.0",
    "prettier": "3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "markdown-it": "^14.1.1",
    "postgres": "^3.4.8"
  }
}
