    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.166.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "wrangler": "^4.73.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
